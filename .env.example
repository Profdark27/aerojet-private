# ═══════════════════════════════════════════════════
# AEROJET PRIVATE — Variabili d'Ambiente
# Copia questo file come .env.local e compila i valori
# ═══════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────
# Development (SQLite - zero configurazione)
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL)
# DATABASE_URL="postgresql://user:password@host:5432/aerojet"

# ─── Anthropic AI (concierge Marco) ────────────────
# Ottieni su: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ─── Avinode (voli privati live) ───────────────────
# Membership richiesta: https://www.avinode.com/become-a-member
# Senza questa chiave, il sistema usa mock data realistici
AVINODE_API_KEY=""
AVINODE_BASE_URL="https://app.avinode.com/avinode/api/v1"

# ─── NextAuth ──────────────────────────────────────
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe (pagamenti) ────────────────────────────
# Dashboard: https://dashboard.stripe.com/
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── Email (Resend) ────────────────────────────────
# Registrati su: https://resend.com/
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="concierge@aerojet.private"

# ─── WhatsApp Business ─────────────────────────────
# Numero con prefisso internazionale, solo cifre (es. 393xxxxxxxxx per Italia)
# NEXT_PUBLIC_ perché usato lato client per generare link wa.me
NEXT_PUBLIC_WHATSAPP_NUMBER="39xxxxxxxxxx"

# ─── Broker Config ────────────────────────────────
# Email del broker per notifiche nuovi lead
BROKER_EMAIL="broker@tuodominio.it"
# Email(s) che ricevono ruolo BROKER automatico al login
BROKER_EMAILS="broker@tuodominio.it"
