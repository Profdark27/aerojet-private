# -----------------------------------------------------------------------------
# AeroJet Private - Deployment Environment Variables Template
# -----------------------------------------------------------------------------

# --- Public Vars (Exposed to Client) ---
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Private Vars (Server-Side Only) ---

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/neondb?sslmode=require"

# Auth (NextAuth)
AUTH_SECRET="your-secret-here"
NEXTAUTH_URL=https://your-domain.vercel.app

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AI & Notifications (Optional but recommended)
ANTHROPIC_API_KEY=sk-ant-at03-...
RESEND_API_KEY=re_...
BROKER_EMAIL=ops@aerojet.app

# LinkedIn Marketing Integration
LINKEDIN_CLIENT_ID=...
LINKEDIN_CLIENT_SECRET=...
