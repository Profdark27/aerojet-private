# ═══════════════════════════════════════════════════
# AEROJET PRIVATE — Variabili d'Ambiente Production
# ═══════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────
# Production (PostgreSQL / Neon)
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# ─── NextAuth v5 ───────────────────────────────────
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-domain.com"
# NextAuth v5 alias (richiesti in produzione)
AUTH_SECRET="your-secret-here"
AUTH_URL="https://your-domain.com"
AUTH_TRUST_HOST="true"
# URL base per link assoluti nelle email e checkout Stripe
NEXT_PUBLIC_BASE_URL="https://your-domain.com"

# ─── Google Auth (Optional) ────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Stripe (Pagamenti Reali) ──────────────────────
# Usa chiavi "live" per produzione, "test" per sandbox
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ─── Email (Resend) ────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="concierge@your-domain.com"

# ─── Broker / Admin Config ─────────────────────────
# Email che riceverà notifiche lead e depositi
BROKER_EMAIL="broker@your-domain.com"
# Lista email separate da virgola che avranno accesso al dashboard (ruolo BROKER)
BROKER_EMAILS="broker@your-domain.com,admin@your-domain.com"

# ─── WhatsApp ──────────────────────────────────────
# Numero per pulsanti WhatsApp (senza + es. 39347...)
NEXT_PUBLIC_WHATSAPP_NUMBER="393..."
# Numero per chiamate concierge (con + es. +39347...)
NEXT_PUBLIC_CONCIERGE_PHONE="+393..."

# ─── AI & Integrazioni (Optional) ──────────────────
# Chiave Anthropic per concierge intelligente
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Flight Operations & Tracking ──────────────────
# Providers: mock | flightaware
FLIGHT_TRACKING_PROVIDER="mock"
# AeroAPI v3 API Key for real-time tail number tracking
FLIGHTAWARE_API_KEY="your-aeroapi-key"

# Audit Logging (Stored in primary DATABASE_URL)
# Every operational change is automatically persisted to AuditLog table.

# Providers: mock | ncc_real
TRANSFER_PROVIDER="mock"
TRANSFER_API_KEY=""

# Providers: mock | catering_real
CATERING_PROVIDER="mock"
CATERING_API_KEY=""

# Providers: mock | twilio | meta
WHATSAPP_PROVIDER="mock"
WHATSAPP_API_KEY=""
WHATSAPP_FROM_NUMBER="+1..."

# ─── Storage & Documents ───────────────────────────
# Providers: mock | vercel-blob | s3
DOCUMENT_STORAGE_PROVIDER="mock"
BLOB_READ_WRITE_TOKEN=""

# ─── Altro ─────────────────────────────────────────
# URL per esportazione lead (Zapier/Make/n8n)
LEAD_WEBHOOK_URL=""
