# ══════════════════════════════════════
# AeroJet Private — Environment Variables
# ══════════════════════════════════════
# Copia in .env.local per sviluppo locale
# Aggiungi su Vercel Dashboard per produzione

# ── Database ──────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/aerojet?sslmode=require"
# Neon: postgresql://...neon.tech/...
# Supabase: postgresql://...supabase.co/...

# ── NextAuth ──────────────────────────
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"
NEXTAUTH_URL="https://tuo-dominio.com"
# Locale: http://localhost:3000

# ── Stripe ────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
# Test: sk_test_...
STRIPE_WEBHOOK_SECRET="whsec_..."
# Ottieni da: Stripe Dashboard → Webhooks → tuo-endpoint → Signing secret
# URL webhook produzione: https://tuo-dominio.com/api/webhooks/stripe

# ── Email ─────────────────────────────
RESEND_API_KEY="re_..."
# Crea su: resend.com → API Keys
# Verifica dominio mittente su Resend prima di usare in produzione

# ── App URL ───────────────────────────
NEXT_PUBLIC_BASE_URL="https://tuo-dominio.com"
# Locale: http://localhost:3000

# ── OAuth (opzionale) ─────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── AI (opzionale — per Operations Brief AI) ──
ANTHROPIC_API_KEY="sk-ant-..."
