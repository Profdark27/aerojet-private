generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          String    @default("CLIENT")
  phone         String?
  company       String?
  createdAt     DateTime  @default(now())
  bookings      Booking[]
  inquiries     Inquiry[]
  chatSessions  ChatSession[]
}

model Operator {
  id             String   @id @default(cuid())
  name           String
  logo           String
  website        String
  fleet          String
  routes         String
  rating         Float    @default(4.5)
  certifications String
  specialty      String
  active         Boolean  @default(true)
  color          String   @default("#1A1A2E")
  bookings       Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  operatorId    String?
  operator      Operator? @relation(fields: [operatorId], references: [id])
  fromICAO      String
  toICAO        String
  fromCity      String
  toCity        String
  departureDate DateTime
  returnDate    DateTime?
  pax           Int
  jetCategory   String
  status        String   @default("PENDING")
  totalPrice    Float?
  commission    Float?
  currency      String   @default("EUR")
  avionodeId    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  quotes        Quote[]
}

model Quote {
  id           String   @id @default(cuid())
  bookingId    String
  booking      Booking  @relation(fields: [bookingId], references: [id])
  operatorName String
  aircraftModel String
  price        Float
  currency     String   @default("EUR")
  validUntil   DateTime
  avionodeId   String?
  commission   Float?
  status       String   @default("PENDING")
  sentAt       DateTime?
  createdAt    DateTime @default(now())
}

model Inquiry {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  name        String
  email       String
  phone       String?
  fromCity    String?
  toCity      String?
  flightDate  String?
  pax         Int?
  budget      String?
  message     String
  flightType  String   @default("oneway")
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  messages  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
