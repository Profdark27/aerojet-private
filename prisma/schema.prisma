generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          String    @default("CLIENT")
  phone         String?
  company       String?
  createdAt     DateTime  @default(now())
  bookings      Booking[]
  inquiries     Inquiry[]
  chatSessions  ChatSession[]
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Operator {
  id             String   @id @default(cuid())
  name           String
  logo           String
  website        String
  fleet          String
  routes         String
  rating         Float    @default(4.5)
  certifications String
  specialty      String
  active         Boolean  @default(true)
  color          String   @default("#1A1A2E")
  bookings       Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  operatorId    String?
  operator      Operator? @relation(fields: [operatorId], references: [id])
  fromICAO      String?
  toICAO        String?
  fromCity      String
  toCity        String
  departureDate DateTime
  returnDate    DateTime?
  pax           Int      @default(1)
  jetCategory   String?
  status        String   @default("PENDING")
  totalPrice    Float?
  commission    Float?
  currency      String   @default("EUR")
  avionodeId    String?
  notes         String?

  // Stripe deposit
  stripeSessionId   String?  @unique
  depositAmount     Float    @default(0)
  depositPaid       Boolean  @default(false)
  depositPaidAt     DateTime?
  confirmationCode  String?  @unique

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  quotes        Quote[]

  @@index([status])
  @@index([createdAt])
}

model Quote {
  id           String   @id @default(cuid())
  bookingId    String?
  booking      Booking?  @relation(fields: [bookingId], references: [id])
  inquiryId    String?
  inquiry      Inquiry?  @relation(fields: [inquiryId], references: [id])
  operatorName String
  aircraftModel String
  price        Float
  currency     String   @default("EUR")
  validUntil   DateTime
  avionodeId   String?
  commission   Float?
  status       String   @default("PENDING")
  sentAt       DateTime?
  createdAt    DateTime @default(now())
}

model Inquiry {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  quotes      Quote[]
  name        String
  email       String
  phone       String?
  fromCity    String?
  toCity      String?
  flightDate  String?
  pax         Int?
  budget      String?
  message     String
  flightType  String   @default("oneway")

  // Pipeline
  status          String  @default("NEW")
  pipelineStatus  String  @default("NEW") // NEW | CONTACTED | QUOTING | QUOTED | WON | LOST

  // Lead scoring
  leadScore         Int     @default(0)
  leadTier          String  @default("UNQUALIFIED") // VIP | HIGH | MEDIUM | LOW | UNQUALIFIED
  budgetNumeric     Float   @default(0)
  urgency           Boolean @default(false)
  sameDay           Boolean @default(false)
  membershipInterest Boolean @default(false)
  suggestedAction   String  @default("")

  // Auto-decision engine
  nextAction    String  @default("") // CALL_NOW | WHATSAPP_NOW | EMAIL_ONLY | LOW_PRIORITY
  urgencyFlag   Boolean @default(false) // sameDay OR date < 48h

  // Broker economics
  operatorCostEstimate Float @default(0)
  clientQuoteEstimate  Float @default(0)
  suggestedQuote       Float @default(0)  // min(budget, operatorCost × 1.25)
  optimizedQuote       Float @default(0)  // tier-based: VIP × 1.35, HIGH × 1.25, MEDIUM × 1.15
  optimizedMargin      Float @default(0)  // optimizedQuote - operatorCostEstimate
  marginEstimate       Float @default(0)
  marginPercent        Float @default(0)
  revenuePotential     Float @default(0)  // = budgetNumeric
  marginRealized       Float @default(0)  // popolato su WON

  // Broker internal
  internalNotes   String?
  nextFollowUpAt  DateTime?   // +30 min
  followUp2hAt    DateTime?   // +2 ore
  followUp24hAt   DateTime?   // +24 ore

  // Stripe deposit
  stripeSessionId  String?  @unique
  depositAmount    Float    @default(0)
  depositPaid      Boolean  @default(false)
  depositPaidAt    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadScore])
  @@index([pipelineStatus])
  @@index([createdAt])
  @@index([leadTier])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  messages  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
