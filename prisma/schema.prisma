generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  role          String        @default("CLIENT")
  phone         String?
  company       String?
  createdAt     DateTime      @default(now())
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  bookings      Booking[]
  chatSessions  ChatSession[]
  inquiries     Inquiry[]
  sessions      Session[]
  auditLogs     AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Operator {
  id             String    @id @default(cuid())
  name           String
  logo           String
  website        String
  fleet          String
  routes         String
  rating         Float     @default(4.5)
  certifications String
  specialty      String
  active         Boolean   @default(true)
  color          String    @default("#1A1A2E")
  bookings       Booking[]
}

model Booking {
  id                  String              @id @default(cuid())
  userId              String?
  operatorId          String?
  fromICAO            String?
  toICAO              String?
  fromCity            String
  toCity              String
  departureDate       DateTime
  returnDate          DateTime?
  pax                 Int                 @default(1)
  jetCategory         String?
  status              String              @default("PENDING")
  totalPrice          Float?
  commission          Float?
  currency            String              @default("EUR")
  avionodeId          String?
  notes               String?
  tailNumber          String?
  handlingAgentFrom   String?
  handlingAgentTo     String?
  paxManifest         String?
  flightStatus        String              @default("SCHEDULED")
  actualDepartureTime DateTime?
  actualArrivalTime   DateTime?
  stripeSessionId     String?             @unique
  depositAmount       Float               @default(0)
  depositPaid         Boolean             @default(false)
  depositPaidAt       DateTime?
  confirmationCode    String?             @unique
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  operator            Operator?           @relation(fields: [operatorId], references: [id])
  user                User?               @relation(fields: [userId], references: [id])
  operationalTasks    OperationalTask[]
  documents           PassengerDocument[]
  quotes              Quote[]

  @@index([status])
  @@index([createdAt])
}

model OperationalTask {
  id                String    @id @default(cuid())
  bookingId         String
  title             String
  description       String?
  category          String
  status            String    @default("PENDING")
  priority          String    @default("NORMAL")
  dueDate           DateTime?
  assignedTo        String?
  vendorName        String?
  vendorContact     String?
  externalReference String?
  cost              Float?
  currency          String    @default("EUR")
  notesInternal     String?
  notesClient       String?
  isClientVisible   Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  booking           Booking   @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([status])
}

model Quote {
  id            String    @id @default(cuid())
  bookingId     String?
  inquiryId     String?
  operatorName  String
  aircraftModel String
  price         Float
  currency      String    @default("EUR")
  validUntil    DateTime
  avionodeId    String?
  commission    Float?
  status        String    @default("PENDING")
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  booking       Booking?  @relation(fields: [bookingId], references: [id])
  inquiry       Inquiry?  @relation(fields: [inquiryId], references: [id])

  @@index([bookingId])
  @@index([inquiryId])
  @@index([status])
}

model Inquiry {
  id                   String    @id @default(cuid())
  userId               String?
  name                 String
  email                String
  phone                String?
  fromCity             String?
  toCity               String?
  flightDate           String?
  pax                  Int?
  budget               String?
  message              String
  flightType           String    @default("oneway")
  status               String    @default("NEW")
  pipelineStatus       String    @default("NEW")
  leadScore            Int       @default(0)
  leadTier             String    @default("UNQUALIFIED")
  budgetNumeric        Float     @default(0)
  urgency              Boolean   @default(false)
  sameDay              Boolean   @default(false)
  membershipInterest   Boolean   @default(false)
  suggestedAction      String    @default("")
  nextAction           String    @default("")
  urgencyFlag          Boolean   @default(false)
  operatorCostEstimate Float     @default(0)
  clientQuoteEstimate  Float     @default(0)
  suggestedQuote       Float     @default(0)
  optimizedQuote       Float     @default(0)
  optimizedMargin      Float     @default(0)
  marginEstimate       Float     @default(0)
  marginPercent        Float     @default(0)
  revenuePotential     Float     @default(0)
  marginRealized       Float     @default(0)
  internalNotes        String?
  nextFollowUpAt       DateTime?
  followUp2hAt         DateTime?
  followUp24hAt        DateTime?
  stripeSessionId      String?   @unique
  depositAmount        Float     @default(0)
  depositPaid          Boolean   @default(false)
  depositPaidAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User?     @relation(fields: [userId], references: [id])
  quotes               Quote[]

  @@index([leadScore])
  @@index([pipelineStatus])
  @@index([createdAt])
  @@index([leadTier])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String?
  messages  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
}

model PassengerDocument {
  id            String                  @id @default(cuid())
  bookingId     String
  type          PassengerDocumentType
  passengerName String?
  fileUrl       String?
  status        PassengerDocumentStatus @default(REQUESTED)
  notesClient   String?
  notesInternal String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  booking       Booking                 @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([status])
}

enum PassengerDocumentType {
  PASSPORT
  VISA
  ID_CARD
  OTHER
}

enum PassengerDocumentStatus {
  REQUESTED
  UPLOADED
  VERIFIED
  REJECTED
}

model AuditLog {
  id        String   @id @default(cuid())
  timestamp DateTime @default(now())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  metadata  String?
  ip        String?
  userAgent String?
  user      User?    @relation(fields: [userId], references: [id])

  @@index([timestamp])
  @@index([entity, entityId])
  @@index([userId])
}
